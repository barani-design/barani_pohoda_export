<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_pohoda" model="ir.ui.view">
        <field name="name">account.move.form.pohoda</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="POHODA Export" name="pohoda_export"
                      groups="barani_pohoda_export.group_export_user">
                    <!-- Ungrouped company_id so the check_company domains on the
                         last_batch_id fields resolve for users who see this page. -->
                    <field name="company_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="barani_pohoda_doc_kind" readonly="1"/>
                            <field name="barani_pohoda_export_state" readonly="1"/>
                            <field name="barani_pohoda_last_batch_id" readonly="1"/>
                            <field name="barani_pohoda_last_success_batch_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="barani_pohoda_exported_at" readonly="1"/>
                            <field name="barani_pohoda_pohoda_record_id" readonly="1"/>
                            <field name="barani_pohoda_export_hash" readonly="1"/>
                        </group>
                    </group>
                    <field name="barani_pohoda_last_error" readonly="1"/>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
