<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Account assignment -->
    <record id="view_pohoda_account_assignment_tree" model="ir.ui.view">
        <field name="name">barani.pohoda.account.assignment.tree</field>
        <field name="model">barani.pohoda.account.assignment</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>
    <record id="view_pohoda_account_assignment_form" model="ir.ui.view">
        <field name="name">barani.pohoda.account.assignment.form</field>
        <field name="model">barani.pohoda.account.assignment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="valid_for"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="action_pohoda_account_assignment" model="ir.actions.act_window">
        <field name="name">Account Assignments</field>
        <field name="res_model">barani.pohoda.account.assignment</field>
        <field name="view_mode">tree,form</field>
    </record>

