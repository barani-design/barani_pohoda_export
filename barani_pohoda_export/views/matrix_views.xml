<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Fiscal profile (matrix column) -->
    <record id="view_pohoda_fiscal_profile_tree" model="ir.ui.view">
        <field name="name">barani.pohoda.fiscal.profile.tree</field>
        <field name="model">barani.pohoda.fiscal.profile</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="geography"/>
                <field name="customer_tax_status"/>
                <field name="account_fiscal_position_ids" widget="many2many_tags" optional="show"/>
                <field name="is_oss"/>
                <field name="blocks_export_when_used"/>
            </tree>
        </field>
    </record>
    <record id="view_pohoda_fiscal_profile_form" model="ir.ui.view">
        <field name="name">barani.pohoda.fiscal.profile.form</field>
        <field name="model">barani.pohoda.fiscal.profile</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="geography"/>
                            <field name="customer_tax_status"/>
                            <field name="is_oss"/>
                        </group>
                        <group>
                            <field name="country_group_id"/>
                            <field name="blocks_export_when_used"/>
                            <field name="requires_accountant_approval"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Linked Odoo fiscal positions">
                        <!-- The resolver maps move.fiscal_position_id -> exactly one
                             active profile through this list. A bare m2m_tags outside
                             a group renders invisibly when empty (16.0.1.11.4 fix). -->
                        <field name="account_fiscal_position_ids" widget="many2many_tags"
                               nolabel="1" colspan="2"
                               placeholder="Add the Odoo fiscal positions this profile represents..."/>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="action_pohoda_fiscal_profile" model="ir.actions.act_window">
        <field name="name">Fiscal Profiles</field>
        <field name="res_model">barani.pohoda.fiscal.profile</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Mapping cell (technical fallback list/form) -->
    <record id="view_pohoda_mapping_cell_tree" model="ir.ui.view">
        <field name="name">barani.pohoda.export.rule.mapping.cell.tree</field>
        <field name="model">barani.pohoda.export.rule.mapping.cell</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="rule_id"/>
                <field name="fiscal_profile_id"/>
                <field name="document_kind"/>
                <field name="enabled_state"/>
                <field name="account_assignment_id"/>
                <field name="downpayment_account_assignment_id" optional="hide"/>
                <field name="vat_classification_id"/>
                <field name="control_statement_code_id"/>
                <field name="moss_service_type_id" optional="hide"/>
                <field name="company_id" invisible="1"/>
            </tree>
        </field>
    </record>
    <record id="view_pohoda_mapping_cell_form" model="ir.ui.view">
        <field name="name">barani.pohoda.export.rule.mapping.cell.form</field>
        <field name="model">barani.pohoda.export.rule.mapping.cell</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="company_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="rule_id"/>
                            <field name="fiscal_profile_id"/>
                            <field name="document_kind"/>
                            <field name="enabled_state"/>
                        </group>
                        <group>
                            <field name="account_assignment_id"/>
                            <field name="downpayment_account_assignment_id"/>
                            <field name="vat_classification_id"/>
                            <field name="control_statement_code_id"/>
                            <field name="moss_service_type_id"/>
                        </group>
                    </group>
                    <group string="Approval">
                        <field name="approved_by" readonly="1"/>
                        <field name="approved_at" readonly="1"/>
                    </group>
                    <field name="accountant_note" placeholder="Accountant note..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="action_pohoda_mapping_cell" model="ir.actions.act_window">
        <field name="name">Mapping Cells (technical)</field>
        <field name="res_model">barani.pohoda.export.rule.mapping.cell</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- DOC 03: the OWL matrix editor (the user-facing UI; the list views above
         remain the technical fallback the spec requires). -->
    <record id="action_pohoda_matrix_editor" model="ir.actions.client">
        <field name="name">Mapping Matrix</field>
        <field name="tag">barani_pohoda_export.matrix_editor</field>
    </record>
</odoo>
