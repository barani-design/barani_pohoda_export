<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== Export wizard ===================== -->
    <record id="view_pohoda_export_wizard_form" model="ir.ui.view">
        <field name="name">barani.pohoda.export.wizard.form</field>
        <field name="model">barani.pohoda.export.wizard</field>
        <field name="arch" type="xml">
            <form string="New POHODA Export">
                <group>
                    <field name="config_id"/>
                    <field name="date_field"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                </group>
                <footer>
                    <button name="action_create_batch" type="object"
                            string="Create &amp; validate batch" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_pohoda_export_wizard" model="ir.actions.act_window">
        <field name="name">New POHODA Export</field>
        <field name="res_model">barani.pohoda.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <!-- The "New Export" menu entry lives in views/menu.xml (loaded last), so the
         parent menu id exists when it loads. -->

    <!-- ===================== Response import wizard ===================== -->
    <record id="view_pohoda_response_import_wizard_form" model="ir.ui.view">
        <field name="name">barani.pohoda.response.import.wizard.form</field>
        <field name="model">barani.pohoda.response.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import POHODA Response">
                <group>
                    <field name="batch_id"/>
                    <field name="response_file" filename="response_filename"/>
                    <field name="response_filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" type="object"
                            string="Import response" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_pohoda_response_import_wizard" model="ir.actions.act_window">
        <field name="name">Import POHODA Response</field>
        <field name="res_model">barani.pohoda.response.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- "Import response" button on the batch (inherits AFTER the action exists). -->
    <record id="view_pohoda_export_batch_form_wizard_buttons" model="ir.ui.view">
        <field name="name">barani.pohoda.export.batch.form.wizard.buttons</field>
        <field name="model">barani.pohoda.export.batch</field>
        <field name="inherit_id" ref="view_pohoda_export_batch_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_mark_sent']" position="after">
                <button name="%(action_pohoda_response_import_wizard)d" type="action"
                        string="Import response" class="oe_highlight" states="sent"
                        groups="barani_pohoda_export.group_export_manager"
                        context="{'default_batch_id': active_id}"/>
            </xpath>
        </field>
    </record>

    <!-- ===================== Re-export authorization ===================== -->
    <record id="view_pohoda_reexport_wizard_form" model="ir.ui.view">
        <field name="name">barani.pohoda.reexport.wizard.form</field>
        <field name="model">barani.pohoda.reexport.wizard</field>
        <field name="arch" type="xml">
            <form string="Authorize POHODA Re-export">
                <div class="alert alert-danger" role="alert"
                     attrs="{'invisible': [('any_unchanged', '=', False)]}">
                    At least one document is UNCHANGED since POHODA accepted it.
                    Re-importing it will create a duplicate document in POHODA.
                </div>
                <group>
                    <field name="move_ids" widget="many2many_tags" readonly="1"/>
                    <field name="any_unchanged" invisible="1"/>
                </group>
                <field name="summary" readonly="1"/>
                <group>
                    <field name="reason" placeholder="Why is this document being re-exported? (recorded in the document's chatter)"/>
                </group>
                <footer>
                    <button name="action_authorize" type="object"
                            string="Authorize re-export" class="btn-primary"
                            confirm="The selected accepted documents will become exportable again. Continue?"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_pohoda_reexport_wizard" model="ir.actions.act_window">
        <field name="name">POHODA: Authorize re-export</field>
        <field name="res_model">barani.pohoda.reexport.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list,form</field>
        <field name="groups_id" eval="[(4, ref('barani_pohoda_export.group_export_manager'))]"/>
    </record>

</odoo>
