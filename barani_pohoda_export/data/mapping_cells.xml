<?xml version='1.0' encoding='utf-8'?>
<odoo>
  <!-- noupdate="1": the POHODA code matrix, seeded once. Invoice cells are
         one per (rule x fiscal profile). The down-payment rule also has explicit
         down_payment_deduction cells for settlement odpočet-zálohy lines. Each
         cell carries the account assignment, VAT classification, control-statement
         (KV) code and, for OSS, the MOSS service type. enabled_state is active /
         blocked / review_required.
         These are MIGRATION-SEED values from the DOC 03 matrix and must be
         accountant-verified (and the dictionary codes given real labels) before
         any production export. -->
  <data noupdate="1">
    <!-- odpocet_zalohy -->
    <record id="cell_odpocet_zalohy_sk_domestic_no_vat_id" model="barani.pohoda.export.rule.mapping.cell">
      <field name="accountant_note">OQ-1 v2 / advance-VAT: a domestic advance is the SK 'dan&#345;ov&#253; doklad k prijatej platbe' - its base posts to 324 (Prijat&#233; preddavky) and it carries the domestic output VAT, declared on receipt (&#167;19(4)). Seeded as the 324 placeholder p&#345;edkont&#225;cia + VAT 'UD'. The matching settlement deduction MUST use the same VAT classification so the final invoice nets to the difference (no double counting). Confirm the exact POHODA p&#345;edkont&#225;cia and Clenenie/KV codes via import test before production (verify_before_production).</field>
      <field name="rule_id" ref="rule_odpocet_zalohy"/>
      <field name="fiscal_profile_id" ref="fp_sk_domestic_no_vat_id"/>
      <field name="document_kind">invoice</field>
      <field name="enabled_state">review_required</field>
      <field name="account_assignment_id" ref="aa_advance_324"/>
      <field name="downpayment_account_assignment_id" ref="aa_advance_324"/>
      <field name="vat_classification_id" ref="vat_ud"/>
      <field name="control_statement_code_id" ref="kv_un"/>
    </record>
